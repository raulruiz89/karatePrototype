#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import json
import logging
import os
import socket
import threading
import time
from datetime import datetime, timezone
from decimal import Decimal, InvalidOperation
from typing import Iterator, Optional

logger = logging.getLogger(__name__)

# How long to wait for gpsd to connect before giving up.
_ACCEPT_TIMEOUT_S = 30
# Poll interval when waiting for gpsd to connect.
_ACCEPT_POLL_S = 0.5
# Internal polling interval used for interruptible waits.
_WAIT_POLL_S = 0.05


class CustomNmeaTcpServer:
    """
    TCP server that listens on a local port and streams NMEA sentences to the
    first client that connects (expected: gpsd in outbound TCP mode).

    Architecture:
        test container                       dev container
        ───────────────────────────          ──────────────────────────────
        CustomNmeaTcpServer                   gpsd (active_connection=tcp)
          172.16.102.1:15555   ◄───────────  dials tcp://172.16.102.1:15555
                                              gpsd JSON API on :2947

    gpsd runs on dev with ``active_connection=tcp`` and ``ip``/``port``
    pointing at this server (172.16.102.1:15555 by default, matching TcpPort in
    nmea_gnss_driver.xml). When PCM launches gpsd it dials out to this server,
    which accepts the connection and then:

      1. Sends a gpsd ``DEVICES`` announcement directly through the socket.
         The selected dataset is never modified.
      2. Streams the dataset once. Sentences sharing the same normalized UTC
         timestamp are treated as one group. A configurable delay is applied
         between sentences in a group, and ``cycle`` is applied only between
         consecutive timestamp groups.
      3. After the last sentence is sent, keeps the TCP connection open (no more
         data) until stop() is called, so gpsd stays connected while the last
         fix ages instead of going offline on socket close.

    Thread state can be observed with ``wait_until_connected()``,
    ``wait_until_dataset_sent()``, ``wait_until_stopped()`` and
    ``raise_if_failed()``.

    Usage::

        server = CustomNmeaTcpServer(port=15555)
        server.select_dataset("/path/to/data.nmea")
        server.start()
        server.wait_until_connected(timeout=30)
        server.wait_until_dataset_sent(timeout=15)
        server.raise_if_failed()
        server.pause()          # optional: stop sending, keep connection open
        server.stop()
    """

    def __init__(
        self,
        port: int = 15555,
        bind_host: str = "172.16.102.1",
        cycle: float = 1.0,
        sentence_interval: float = 0.05,
    ):
        """
        Args:
            port: TCP port to bind and listen on. Should match the TcpPort value
                in the test system XML config (nmea_gnss_driver.xml), i.e. 15555.
            bind_host: Address to bind to. Defaults to 172.16.102.1, the test
                container address that gpsd dials out to.
            cycle: Delay in seconds between consecutive NMEA timestamp groups.
                It is not applied after the final group. The dataset is streamed
                once (no looping).
            sentence_interval: Delay in seconds between sentences belonging to
                the same timestamp group. This preserves a controlled line order
                while still presenting all candidates as one GNSS epoch.
        """
        if cycle < 0:
            raise ValueError("cycle must be greater than or equal to 0.")
        if sentence_interval < 0:
            raise ValueError("sentence_interval must be greater than or equal to 0.")

        self._port = port
        self._bind_host = bind_host
        self._cycle = cycle
        self._sentence_interval = sentence_interval
        self._dataset: Optional[str] = None
        self._thread: Optional[threading.Thread] = None
        self._stop_event = threading.Event()
        self._pause_event = threading.Event()
        self._connected_event = threading.Event()
        self._dataset_sent_event = threading.Event()
        self._stopped_event = threading.Event()
        self._failed_event = threading.Event()
        self._server_sock: Optional[socket.socket] = None
        self._client_sock: Optional[socket.socket] = None
        self._error: Optional[BaseException] = None

    @property
    def port(self) -> int:
        return self._port

    @property
    def is_running(self) -> bool:
        return self._thread is not None and self._thread.is_alive()

    @property
    def is_paused(self) -> bool:
        return self._pause_event.is_set()

    @property
    def is_connected(self) -> bool:
        return self._connected_event.is_set()

    @property
    def is_dataset_sent(self) -> bool:
        return self._dataset_sent_event.is_set()

    @property
    def has_failed(self) -> bool:
        return self._failed_event.is_set()

    @property
    def error(self) -> Optional[BaseException]:
        return self._error

    def pause(self) -> None:
        """
        Stop streaming NMEA sentences while keeping the client connection open.

        gpsd stays connected (device remains online) but stops receiving fresh
        fixes, so the task's data ages and eventually crosses the stale-data
        threshold. This differs from stop(), which closes the sockets and makes
        the device go offline.
        """
        self._pause_event.set()
        logger.info("NMEA streaming paused (TCP connection kept open).")

    def resume(self) -> None:
        """Resume streaming NMEA sentences after a pause()."""
        self._pause_event.clear()
        logger.info("NMEA streaming resumed.")

    def select_dataset(self, dataset_path: str) -> None:
        """
        Select the NMEA dataset file to stream.

        Raises:
            FileNotFoundError: If the dataset file does not exist.
            RuntimeError: If the server is already running.
        """
        if self.is_running:
            raise RuntimeError("Cannot change dataset while server is running.")
        if not os.path.isfile(dataset_path):
            raise FileNotFoundError(f"Dataset not found: {dataset_path}")
        self._dataset = os.path.abspath(dataset_path)
        logger.info("Dataset selected: %s", self._dataset)

    def start(self) -> None:
        """
        Bind the server socket and start the background streaming thread.

        The port is bound before this method returns, so callers can start the
        stack that triggers gpsd to connect immediately afterward.

        Raises:
            RuntimeError: If already running or no dataset selected.
            OSError: If the server socket cannot be created, bound or configured.
        """
        if self.is_running:
            raise RuntimeError("NMEA TCP server is already running.")
        if not self._dataset:
            raise RuntimeError("No dataset selected. Call select_dataset() first.")

        self._reset_run_state()

        self._server_sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        self._server_sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        self._server_sock.bind((self._bind_host, self._port))
        self._server_sock.listen(1)
        self._server_sock.settimeout(_ACCEPT_POLL_S)

        self._thread = threading.Thread(
            target=self._server_loop,
            name="NmeaTcpServer",
            daemon=True,
        )
        self._thread.start()
        logger.info("NMEA TCP server listening on %s:%s", self._bind_host, self._port)

    def stop(self) -> None:
        """Stop the background thread and close the client and server sockets."""
        if not self.is_running:
            self._close_socket("_client_sock")
            self._close_socket("_server_sock")
            self._stopped_event.set()
            logger.info("NMEA server is not running, nothing to stop.")
            return

        logger.info("Stopping NMEA TCP server...")
        self._stop_event.set()
        self._pause_event.clear()
        self._close_socket("_client_sock")
        self._close_socket("_server_sock")

        assert self._thread is not None
        self._thread.join(timeout=10)
        if self._thread.is_alive():
            raise RuntimeError("NMEA TCP server thread did not stop within 10 seconds.")
        self._thread = None
        logger.info("NMEA TCP server stopped.")

    def wait_until_connected(self, timeout: Optional[float] = None) -> bool:
        """Wait until gpsd connects. Return False on timeout and raise on failure."""
        completed = self._wait_for_event_or_failure(self._connected_event, timeout)
        self.raise_if_failed()
        return completed

    def wait_until_dataset_sent(self, timeout: Optional[float] = None) -> bool:
        """Wait until the complete dataset has been sent. Raise on failure."""
        completed = self._wait_for_event_or_failure(self._dataset_sent_event, timeout)
        self.raise_if_failed()
        return completed

    def wait_until_stopped(self, timeout: Optional[float] = None) -> bool:
        """Wait until the server thread exits. Raise if it exited due to failure."""
        completed = self._stopped_event.wait(timeout)
        self.raise_if_failed()
        return completed

    def raise_if_failed(self) -> None:
        """Raise RuntimeError chained from the background thread exception."""
        if self._failed_event.is_set():
            error = self._error or RuntimeError("Unknown NMEA TCP server failure.")
            raise RuntimeError(f"NMEA TCP server failed: {error}") from error

    def _reset_run_state(self) -> None:
        self._stop_event.clear()
        self._pause_event.clear()
        self._connected_event.clear()
        self._dataset_sent_event.clear()
        self._stopped_event.clear()
        self._failed_event.clear()
        self._error = None
        self._client_sock = None

    def _server_loop(self) -> None:
        """Background thread: wait for gpsd, send DEVICES, then stream NMEA."""
        try:
            self._accept_client()
            if self._stop_event.is_set() or self._client_sock is None:
                return

            devices_msg = self._build_devices_message()
            self._send_line(devices_msg)
            logger.info("DEVICES announcement sent directly to gpsd.")

            groups = iter(self._iter_timestamp_groups())
            try:
                current_group = next(groups)
            except StopIteration:
                logger.info("NMEA dataset contains no streamable sentences.")
                self._dataset_sent_event.set()
            else:
                while True:
                    self._send_group(current_group)
                    try:
                        next_group = next(groups)
                    except StopIteration:
                        break

                    if not self._interruptible_sleep(self._cycle):
                        return
                    current_group = next_group

                self._dataset_sent_event.set()
                logger.info("NMEA TCP server: dataset sent once.")

            # Keep the connection open so gpsd remains online while the last fix
            # ages. stop() sets the event and closes the client socket.
            logger.info("NMEA TCP server: holding connection open.")
            while not self._stop_event.wait(0.2):
                pass
        except BaseException as exc:
            if not self._stop_event.is_set():
                self._record_failure(exc)
        finally:
            self._close_socket("_client_sock")
            self._close_socket("_server_sock")
            self._stopped_event.set()
            logger.info("NMEA TCP server thread exited.")

    def _accept_client(self) -> None:
        logger.info(
            "Waiting for gpsd to connect on port %s (timeout %ss)...",
            self._port,
            _ACCEPT_TIMEOUT_S,
        )
        deadline = time.monotonic() + _ACCEPT_TIMEOUT_S

        while not self._stop_event.is_set() and time.monotonic() < deadline:
            try:
                if self._server_sock is None:
                    return
                client_sock, addr = self._server_sock.accept()
                self._client_sock = client_sock
                self._connected_event.set()
                logger.info("gpsd connected from %s", addr)
                return
            except socket.timeout:
                continue
            except OSError:
                if self._stop_event.is_set():
                    return
                raise

        if not self._stop_event.is_set():
            raise TimeoutError(
                f"gpsd did not connect within {_ACCEPT_TIMEOUT_S} seconds"
            )

    def _send_group(self, group: list[str]) -> None:
        for index, sentence in enumerate(group):
            if not self._wait_while_paused():
                return
            self._send_line(sentence)

            is_last_sentence = index == len(group) - 1
            if not is_last_sentence and not self._interruptible_sleep(
                self._sentence_interval
            ):
                return

    def _send_line(self, line: str) -> None:
        if self._stop_event.is_set():
            return
        if self._client_sock is None:
            raise ConnectionError("No gpsd client socket is connected.")

        # NMEA and the synthetic DEVICES announcement must be ASCII. Strict
        # encoding prevents an invalid dataset character from being replaced
        # silently and later appearing as a gpsd parsing/checksum problem.
        payload = f"{line}\r\n".encode("ascii", errors="strict")
        try:
            self._client_sock.sendall(payload)
        except (BrokenPipeError, ConnectionResetError) as exc:
            raise ConnectionError("gpsd disconnected during streaming") from exc

    def _wait_while_paused(self) -> bool:
        while self._pause_event.is_set():
            if self._stop_event.wait(0.2):
                return False
        return not self._stop_event.is_set()

    def _interruptible_sleep(self, duration: float) -> bool:
        """Sleep unless stop() is requested; return False when interrupted."""
        if duration <= 0:
            return not self._stop_event.is_set()
        return not self._stop_event.wait(duration)

    def _wait_for_event_or_failure(
        self, event: threading.Event, timeout: Optional[float]
    ) -> bool:
        deadline = None if timeout is None else time.monotonic() + timeout
        while True:
            if event.is_set():
                return True
            if self._failed_event.is_set():
                return False
            if self._stopped_event.is_set() and not event.is_set():
                return False
            if deadline is not None:
                remaining = deadline - time.monotonic()
                if remaining <= 0:
                    return False
                wait_time = min(_WAIT_POLL_S, remaining)
            else:
                wait_time = _WAIT_POLL_S
            event.wait(wait_time)

    def _record_failure(self, exc: BaseException) -> None:
        self._error = exc
        self._failed_event.set()
        logger.exception("NMEA TCP server failed", exc_info=exc)

    def _close_socket(self, attribute_name: str) -> None:
        sock = getattr(self, attribute_name)
        if sock is None:
            return
        try:
            sock.shutdown(socket.SHUT_RDWR)
        except OSError:
            pass
        try:
            sock.close()
        except OSError:
            pass
        setattr(self, attribute_name, None)

    def _build_devices_message(self) -> str:
        """
        Build the gpsd DEVICES announcement sent before NMEA streaming begins.

        The device path is derived from the server's bind address and port. The
        activated timestamp reflects when gpsd connected and uses UTC ISO 8601
        with millisecond precision.
        """
        now = datetime.now(timezone.utc)
        activated = (
            now.strftime("%Y-%m-%dT%H:%M:%S.")
            + f"{now.microsecond // 1000:03d}Z"
        )
        message = {
            "class": "DEVICES",
            "devices": [
                {
                    "class": "DEVICE",
                    "path": f"tcp://{self._bind_host}:{self._port}",
                    "driver": "NMEA0183",
                    "activated": activated,
                    "flags": 1,
                }
            ],
        }
        return json.dumps(message, separators=(",", ":"))

    @staticmethod
    def _extract_timestamp(sentence: str) -> Optional[int]:
        """
        Return normalized UTC microseconds since midnight, or None.

        Comparing a numeric time value means equivalent representations such as
        ``150000``, ``150000.0`` and ``150000.000`` belong to the same group.
        Invalid UTC fields raise ValueError instead of silently creating an
        incorrect group.
        """
        body = sentence.split("*", 1)[0]
        fields = body.split(",")
        if not fields or not fields[0]:
            return None

        msg_type = fields[0][-3:]
        time_field_index = {
            "GGA": 1,
            "RMC": 1,
            "GLL": 5,
            "GST": 1,
            "ZDA": 1,
            "GNS": 1,
            "GBS": 1,
        }
        idx = time_field_index.get(msg_type)
        if idx is None or idx >= len(fields) or not fields[idx]:
            return None

        raw_time = fields[idx]
        try:
            numeric_time = Decimal(raw_time)
        except InvalidOperation as exc:
            raise ValueError(
                f"Invalid UTC time '{raw_time}' in NMEA sentence: {sentence}"
            ) from exc

        hours = int(numeric_time // Decimal("10000"))
        remainder = numeric_time - Decimal(hours * 10000)
        minutes = int(remainder // Decimal("100"))
        seconds = remainder - Decimal(minutes * 100)

        if not 0 <= hours <= 23:
            raise ValueError(f"Invalid UTC hour in NMEA sentence: {sentence}")
        if not 0 <= minutes <= 59:
            raise ValueError(f"Invalid UTC minute in NMEA sentence: {sentence}")
        if not Decimal("0") <= seconds < Decimal("60"):
            raise ValueError(f"Invalid UTC second in NMEA sentence: {sentence}")

        total_seconds = Decimal(hours * 3600 + minutes * 60) + seconds
        # NMEA timestamps commonly provide fractional seconds. Microseconds give
        # a stable, exact grouping key without binary floating-point artifacts.
        return int(total_seconds * Decimal("1000000"))

    def _iter_timestamp_groups(self) -> Iterator[list[str]]:
        """
        Yield ordered sentence groups sharing the same normalized UTC time.

        Sentences without a timestamp (for example GSA, GSV, VTG and HDT) are
        attached to the current group. Therefore datasets should place them
        after a timestamped sentence belonging to their intended GNSS epoch.
        """
        if not self._dataset:
            raise RuntimeError("No dataset selected.")

        current_group: list[str] = []
        current_ts: Optional[int] = None

        with open(self._dataset, "r", encoding="ascii", errors="strict") as fh:
            for line_number, raw in enumerate(fh, start=1):
                line = raw.strip()
                if not line or line.startswith("#"):
                    continue
                try:
                    timestamp = self._extract_timestamp(line)
                except ValueError as exc:
                    raise ValueError(
                        f"Invalid dataset line {line_number}: {exc}"
                    ) from exc

                if (
                    timestamp is not None
                    and current_group
                    and current_ts is not None
                    and timestamp != current_ts
                ):
                    yield current_group
                    current_group = []

                if timestamp is not None:
                    current_ts = timestamp
                current_group.append(line)

        if current_group:
            yield current_group
